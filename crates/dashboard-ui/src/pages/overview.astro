---
import Layout from '../layouts/Layout.astro';
import Overview from '../components/Overview';
---

<Layout title="Switchyard - Overview">
  <div style={{ display: 'flex', minHeight: '100vh' }}>
    <nav style={{
      width: '240px', background: '#18181b', borderRight: '1px solid #27272a',
      padding: '24px 16px', display: 'flex', flexDirection: 'column', gap: '8px', flexShrink: 0,
    }}>
      <div style={{ fontSize: '18px', fontWeight: 700, padding: '0 12px 20px', borderBottom: '1px solid #27272a', marginBottom: '8px' }}>
        ⚡ Switchyard
      </div>
      <a href="/overview" style="display:block;padding:10px 12px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;color:#fafafa;background:#27272a;">Overview</a>
      <a href="/routes" style="display:block;padding:10px 12px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;color:#a1a1aa;">Routes</a>
      <a href="/config" style="display:block;padding:10px 12px;border-radius:8px;text-decoration:none;font-size:14px;font-weight:500;color:#a1a1aa;">Config</a>
    </nav>
    <main style={{ flex: 1, padding: '32px', overflowY: 'auto' }}>
      <Overview client:load />
    </main>
  </div>
</Layout>
